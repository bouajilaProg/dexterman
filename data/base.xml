<?xml version="1.0" encoding="UTF-8"?>
<collection>
  <env>
    <var name="API_URL" value="http://localhost:3001" />
  </env>

  <api name="health check" method="GET" path="{{API_URL}}/health">
    <request>
      <body></body>
    </request>
    <response>
      <body>
        <field name="status" type="string" />
        <field name="uptime" type="number" />
        <field name="version" type="string" />
      </body>
    </response>
  </api>

  <api name="site config" method="GET" path="{{API_URL}}/config/public">
    <request>
      <body></body>
    </request>
    <response>
      <body>
        <field name="siteName" type="string" />
        <field name="supportEmail" type="string" />
        <field name="currency" type="string" />
      </body>
    </response>
  </api>

  <group name="users">
    <api name="list users" method="GET" path="{{API_URL}}/testAPI/users">
      <request>
        <body></body>
      </request>
      <response>
        <body>
          <field name="ok" type="boolean" />
          <field name="count" type="number" />
          <field name="items" type="array&lt;object&gt;" />
        </body>
      </response>
    </api>

    <api name="create user" method="POST" path="{{API_URL}}/testAPI/users">
      <request>
        <body>
          <field name="email" type="string" required="true" />
          <field name="role" type="string" required="false" />
        </body>
      </request>
      <response>
        <body>
          <field name="ok" type="boolean" />
          <field name="item" type="object" />
        </body>
      </response>
    </api>

    <api name="get user" method="GET" path="{{API_URL}}/testAPI/users/:id">
      <request>
        <body></body>
      </request>
      <response>
        <body>
          <field name="ok" type="boolean" />
          <field name="item" type="object" />
        </body>
      </response>
    </api>

    <api name="delete user" method="DELETE" path="{{API_URL}}/testAPI/users/:id">
      <request>
        <body></body>
      </request>
      <response>
        <body>
          <field name="ok" type="boolean" />
          <field name="deleted" type="object" />
        </body>
      </response>
    </api>
  </group>

  <group name="catalog">
    <api name="list products" method="GET" path="{{API_URL}}/products">
      <request>
        <body></body>
      </request>
      <response>
        <body>
          <field name="items" type="array&lt;object&gt;" />
          <field name="total" type="number" />
        </body>
      </response>
    </api>
  </group>
</collection>
