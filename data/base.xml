<?xml version="1.0" encoding="UTF-8"?>
<collection>
  <env>
    <var name="API_URL" value="https://api.example.com" />
  </env>
  <group name="auth">
    <api name="login" method="POST" path="/auth/login/imed">
      <request>
        <body>
          <field name="imed" type="string" required="true" />
          <field name="password" type="string" required="true" />
        </body>
      </request>
      <response>
        <body>
        </body>
      </response>
    </api>
  </group>
  <group name="users">
    <api name="user" method="POST" path="/users/{family}">
      <request>
        <body>
          <field name="username" type="string" required="true" />
          <field name="email" type="string" required="true" />
          <field name="password" type="string" required="true" />
        </body>
      </request>
      <response>
        <body>
          <field name="id" type="string" />
          <field name="username" type="string" />
          <field name="email" type="string" />
        </body>
      </response>
    </api>
  </group>
</collection>
