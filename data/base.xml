<?xml version="1.0" encoding="UTF-8"?>
<collection>
  <env>
    <var name="API_URL" value="https://api.example.com" />
  </env>
  <api name="rootapi" method="GET" path="/root">
    <request>
      <body>
      </body>
    </request>
    <response>
      <body>
      </body>
    </response>
  </api>
  <group name="auth2">
    <api name="users family" method="POST" path="/users/{family}">
      <request>
        <body>
          <field name="username" type="string" required="true" />
          <field name="email" type="string" required="true" />
          <field name="password" type="string" required="true" />
        </body>
      </request>
      <response>
        <body>
          <field name="id" type="string" />
          <field name="username" type="string" />
          <field name="email" type="string" />
        </body>
      </response>
    </api>
  </group>
  <group name="user">
    <api name="users" method="GET" path="/users">
      <request>
        <body>
        </body>
      </request>
      <response>
        <body>
        </body>
      </response>
    </api>
  </group>
</collection>
