{
  "name": "dexterman",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:css\"",
    "dev:test-api": "node testAPI/server.mjs",
    "docker:dev": "pnpm run build:client && concurrently \"pnpm run dev:server\" \"pnpm run dev:css\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch src/index.tsx",
    "dev:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --watch",
    "dev:client": "tsc --watch --preserveWatchOutput",
    "build:client": "tsc",
    "build": "pnpm run build:css && tsc && pnpm run build:copy",
    "build:copy": "node scripts/copy-assets.mjs",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --minify",
    "prestart": "pnpm run build",
    "start": "node dist/index.js",
    "start:test-api": "node testAPI/server.mjs",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.12",
    "linkedom": "^0.18.12",
    "lucide": "^1.8.0",
    "xslt-processor": "^5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^20.11.17",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "impeccable": "^2.1.7",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
